{
  "mcpServers": {
    "warpdesk-tickets": {
      "command": "npm",
      "args": ["run", "mcp:tickets"],
      "cwd": ".",
      "env": {
        "WARPDESK_BASE_URL": "https://your-app.example.com",
        "WARPDESK_PERSONAL_ACCESS_TOKEN": "wds_pat_paste_token_from_app_settings"
      }
    }
  }
}
